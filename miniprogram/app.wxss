page {
  background: #f5f7fb;
  color: #172821;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", sans-serif;
  font-size: 28rpx;
}
button {
  border-radius: 999rpx;
  border: 0;
  transition: transform 120ms ease, opacity 120ms ease;
}
button[disabled] {
  opacity: 0.58;
}
button::after {
  border: 0;
}
.container { padding: 28rpx; }
.card {
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 32rpx;
  box-shadow: 0 18rpx 48rpx rgba(45, 63, 54, 0.08);
  padding: 28rpx;
  margin-bottom: 24rpx;
}
.primary {
  background: linear-gradient(135deg, #1f6b57, #172821);
  color: #fff;
  border: 0;
}
.secondary {
  background: #edf3ef;
  color: #28463b;
  border: 0;
}
.danger {
  background: #fff0ed;
  color: #d84c3f;
  border: 0;
}
.muted { color: #7b867f; }
.badge {
  display: inline-block;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e7f3ee;
  color: #2f6f5e;
  font-size: 22rpx;
}
.input, textarea, picker {
  background: #fff;
  border: 1rpx solid rgba(40, 70, 59, 0.09);
  border-radius: 22rpx;
  padding: 20rpx;
  box-sizing: border-box;
}
