<view class="peoplePage">
  <view class="peopleHero">
    <view class="heroGlow"></view>
    <view>
      <text class="eyebrow">ACCESS</text>
      <view class="title">人员与权限</view>
      <view class="heroSub">当前身份：{{user.name || '加载中'}} · {{user.roleLabel || ''}}</view>
    </view>
    <view class="heroBadge">{{users.length}} 人</view>
  </view>

  <view wx:if="{{editingUserId}}" class="card formCard editCard">
    <view class="editHeader">
      <view>
        <view class="sectionTitle">{{editingTargetActive ? '编辑成员权限' : '审核配置成员'}}</view>
        <view class="muted smallTip">审核或变更后会立即影响小程序可见范围和可操作功能。</view>
      </view>
      <text class="spark">✦</text>
    </view>
    <input class="input" placeholder="姓名" value="{{editName}}" bindinput="onEditNameInput" />
    <picker range="{{roleOptions}}" range-key="label" value="{{editRoleIndex}}" bindchange="onEditRoleChange">
      <view class="pickerLine">角色：{{roleOptions[editRoleIndex].label}}</view>
    </picker>
    <view class="permissionPanel" wx:if="{{canManagePermissions}}">
      <view class="permissionTitle">额外权限</view>
      <view class="muted smallTip">角色自带权限不用重复勾选；这里只配置额外授权。</view>
      <checkbox-group bindchange="onEditPermissionsChange">
        <label class="permissionItem" wx:for="{{permissionOptions}}" wx:key="key">
          <checkbox value="{{item.key}}" checked="{{editPermissions.indexOf(item.key) >= 0}}" />
          <text>{{item.label}}</text>
        </label>
      </checkbox-group>
    </view>
    <view class="actions stickyActions">
      <button class="secondary" disabled="{{submitting}}" bindtap="cancelEdit">取消</button>
      <button class="primary" wx:if="{{editingTargetActive}}" loading="{{submitting}}" disabled="{{submitting}}" bindtap="saveEdit">{{submitting ? '保存中...' : '保存修改'}}</button>
      <button class="primary" wx:else loading="{{submitting}}" disabled="{{submitting}}" bindtap="reviewUser">{{submitting ? '审核中...' : '审核通过'}}</button>
    </view>
  </view>

  <view class="peopleStats">
    <view><text>{{activeCount}}</text><span>已启用成员</span></view>
    <view><text>{{boundCount}}</text><span>已绑定微信</span></view>
    <view><text>{{pendingCount}}</text><span>待审核/停用</span></view>
  </view>

  <scroll-view class="peopleList" scroll-y enhanced show-scrollbar="{{false}}">
    <view class="userCard {{expandedUserId === item._id ? 'expanded' : ''}}" wx:for="{{users}}" wx:key="_id">
      <view class="statusStrip {{item.active ? 'active' : 'pending'}}"></view>
      <view class="userTop compactUserTop" data-id="{{item._id}}" bindtap="toggleExpand">
        <view class="avatar">{{item.avatarText}}</view>
        <view class="userMain">
          <view class="nameRow">
            <view class="name">{{item.name}}</view>
            <text class="badge roleBadge">{{item.roleLabel}}</text>
          </view>
          <view class="muted metaLine">{{item.active ? '已启用' : '待审核'}} · 微信{{item.openid ? '已绑定' : '未绑定'}} · 额外权限 {{item.permissions.length}}</view>
        </view>
        <text class="expandHint">{{expandedUserId === item._id ? '收起' : '展开'}}</text>
      </view>
      <view wx:if="{{expandedUserId === item._id}}" class="expandedPanel">
        <view class="permissionChips" wx:if="{{item.permissions.length}}">
          <text wx:for="{{item.permissions}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="actions">
          <button class="secondary" disabled="{{submitting}}" wx:if="{{canManageUsers}}" data-user="{{item}}" bindtap="startEdit">{{item.active ? '编辑权限' : '审核配置'}}</button>
          <button class="secondary" disabled="{{submitting}}" data-user="{{item}}" bindtap="bindSelf" wx:if="{{!item.openid}}">绑定当前微信</button>
          <button class="secondary" disabled="{{submitting}}" wx:if="{{canManageUsers && item.openid}}" data-user="{{item}}" bindtap="unbind">解绑微信</button>
          <button class="danger" disabled="{{submitting}}" wx:if="{{canManageUsers}}" data-user="{{item}}" bindtap="toggleActive">{{item.active ? '停用' : '启用'}}</button>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
