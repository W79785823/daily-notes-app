page {
  background: linear-gradient(180deg, #f5f7fb 0%, #eef4f1 52%, #fff7ec 100%);
}
.peoplePage {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
}
.peopleHero {
  position: relative;
  overflow: hidden;
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 24rpx;
  border-radius: 38rpx;
  padding: 34rpx;
  color: #fff;
  background: linear-gradient(135deg, #172821 0%, #276b5a 56%, #f0a84f 150%);
  box-shadow: 0 26rpx 60rpx rgba(23, 40, 33, 0.2);
  margin-bottom: 24rpx;
}
.heroGlow {
  position: absolute;
  right: -100rpx;
  top: -120rpx;
  width: 280rpx;
  height: 280rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.18);
}
.eyebrow {
  font-size: 22rpx;
  color: rgba(255,255,255,.68);
  letter-spacing: 4rpx;
}
.title {
  font-size: 48rpx;
  line-height: 1.15;
  font-weight: 900;
  margin: 12rpx 0;
}
.heroSub {
  color: rgba(255,255,255,.76);
  font-size: 24rpx;
}
.heroBadge {
  position: relative;
  z-index: 1;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255,255,255,.16);
  border: 1rpx solid rgba(255,255,255,.22);
  font-size: 24rpx;
  white-space: nowrap;
}
.sectionTitle {
  font-size: 32rpx;
  font-weight: 900;
  color: #172821;
}
.editHeader {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 10rpx;
}
.spark { font-size: 42rpx; color: #e7a13d; }
.formCard input,
.formCard picker,
.formCard button {
  margin-top: 16rpx;
}
.pickerLine {
  background: #fff;
  border: 1rpx solid rgba(40, 70, 59, 0.09);
  border-radius: 22rpx;
  padding: 20rpx;
  color: #283a34;
  font-size: 25rpx;
}
.editCard {
  border: 2rpx solid rgba(47, 111, 94, 0.18);
}
.permissionPanel {
  margin-top: 18rpx;
  border-radius: 26rpx;
  padding: 20rpx;
  background: rgba(247, 250, 248, .86);
  border: 1rpx solid rgba(40,70,59,.08);
}
.permissionTitle {
  font-size: 28rpx;
  font-weight: 900;
  color: #172821;
}
.permissionItem {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 14rpx 0;
  color: #4f5d56;
  font-size: 26rpx;
  border-bottom: 1rpx solid rgba(40,70,59,.06);
}
.permissionItem:last-child { border-bottom: 0; }
.smallTip {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.5;
}
.actions {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 22rpx;
}
.actions button {
  flex: 1;
  min-width: 160rpx;
  height: 72rpx;
  line-height: 72rpx;
  font-size: 24rpx;
  padding-left: 8rpx;
  padding-right: 8rpx;
}
.stickyActions {
  padding-top: 6rpx;
}
.peopleStats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-bottom: 22rpx;
}
.peopleStats view {
  border-radius: 28rpx;
  padding: 20rpx;
  background: rgba(255,255,255,.72);
  box-shadow: 0 12rpx 34rpx rgba(45,63,54,.07);
}
.peopleStats text {
  display: block;
  color: #1f6b57;
  font-size: 38rpx;
  font-weight: 900;
}
.peopleStats span {
  display: block;
  color: #7b867f;
  font-size: 22rpx;
  margin-top: 4rpx;
}
.peopleList {
  max-height: 1180rpx;
  border-radius: 32rpx;
  padding-bottom: 20rpx;
}
.userCard {
  position: relative;
  overflow: hidden;
  background: rgba(255,255,255,.84);
  border: 1rpx solid rgba(255,255,255,.78);
  border-radius: 32rpx;
  box-shadow: 0 18rpx 48rpx rgba(45,63,54,.08);
  padding: 26rpx;
  margin-bottom: 22rpx;
}
.userCard.expanded {
  background: rgba(255,255,255,.92);
  box-shadow: 0 22rpx 54rpx rgba(45,63,54,.11);
}
.compactUserTop {
  cursor: pointer;
}
.expandHint {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #eef6f2;
  color: #2d6b5c;
  font-size: 22rpx;
  font-weight: 800;
}
.expandedPanel {
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(40,70,59,.08);
}
.statusStrip {
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 10rpx;
  background: #f0a84f;
}
.statusStrip.active { background: #1f9d72; }
.statusStrip.pending { background: #d84c3f; }
.userTop {
  display: flex;
  align-items: center;
  gap: 18rpx;
}
.avatar {
  width: 76rpx;
  height: 76rpx;
  display: grid;
  place-items: center;
  border-radius: 24rpx;
  color: #fff;
  background: linear-gradient(135deg, #244c3b, #d69848);
  font-weight: 900;
  font-size: 30rpx;
}
.userMain { flex: 1; min-width: 0; }
.nameRow {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}
.name {
  flex: 1;
  min-width: 0;
  color: #172821;
  font-size: 34rpx;
  font-weight: 900;
}
.roleBadge { flex: 0 0 auto; }
.metaLine {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
}
.permissionChips {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}
.permissionChips text {
  max-width: 300rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  padding: 8rpx 12rpx;
  border-radius: 999rpx;
  background: #eef6f2;
  color: #2d6b5c;
  font-size: 21rpx;
}
