DATABASE_URL="postgresql://daily_notes:password@localhost:54329/daily_notes?schema=public"
# 生产环境必须改为高强度随机值，且不要提交真实密钥
SESSION_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"
# 本地开发可为 true；生产 Web/API 环境必须设为 false，避免接受 x-user-id / ?userId= 调试身份
AUTH_ALLOW_DEV_USER_HEADER="false"

# 部署后用一次性环境变量执行 npm run bootstrap:superadmin 创建/重置平台超管；不要把真实超管密码写进 .env 或提交到仓库
SUPER_ADMIN_LOGIN="platform-admin"
SUPER_ADMIN_PASSWORD="change-me-before-bootstrap"
